APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Karachi

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# First admin (DatabaseSeeder). Password is only applied when the user is created; change via app or re-create user.
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Administrator
ADMIN_PASSWORD=password

# HMS: set false in production so only staff/admin see reception and only admin sees settings CRUDs.
HMS_SKIP_ROLE_PAGE_GUARDS=true
HMS_CLINIC_NAME=MMC
# Optional: X-HMS-Control-Secret header for token-screen corner buttons on TVs without staff login
TOKEN_SCREEN_CONTROL_SECRET=

# VeevoTech SMS (appointments + broadcast) — POST https://api.veevotech.com/v3/sendsms
HMS_SMS_ENABLED=false
VEEVOTECH_SMS_HASH=
VEEVOTECH_SMS_SENDER=Default
VEEVOTECH_SMS_TIMEOUT=15
# Shift close summary SMS (owner + finance manager, Pakistan format e.g. 03XXXXXXXXX)
HMS_SHIFT_CLOSE_SMS_OWNER=
HMS_SHIFT_CLOSE_SMS_FINANCE=

# Outbound: POST lab cases to external lab HMS (Bearer must match lab server HMS_API_TOKEN)
HMS_LAB_CASES_SYNC_ENABLED=true
HMS_LAB_CASES_API_URL=https://lab.mohsinmedicalcomplex.com
HMS_LAB_CASES_API_TOKEN=
HMS_LAB_CASES_API_TIMEOUT=15
# Receipt / invoice id sent to lab (prefix + local invoice id)
HMS_LAB_CASES_INVOICE_PREFIX=HS-
# Patients with gender "other" are sent as this value (API accepts only male/female)
HMS_LAB_CASES_FALLBACK_GENDER=male

VITE_APP_NAME="${APP_NAME}"
